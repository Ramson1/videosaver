# ============================================
# VideoSaver Environment Configuration
# ============================================

# Application
NODE_ENV=development
PORT=3000
API_PORT=4000

# Frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=downloads

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Database (if using direct PostgreSQL connection)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/videosaver

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Rate Limiting
RATE_LIMIT_GUEST_DAILY=10
RATE_LIMIT_USER_DAILY=100
RATE_LIMIT_PREMIUM_DAILY=-1

# Storage
STORAGE_TEMP_DIR=./tmp/downloads
STORAGE_MAX_FILE_SIZE_MB=500
STORAGE_CLEANUP_INTERVAL_HOURS=24
STORAGE_SIGNED_URL_EXPIRY_SECONDS=3600

# FFmpeg
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty

# Security
CORS_ORIGINS=http://localhost:3000
HELMET_ENABLED=true

# Queue
BULLMQ_CONCURRENCY=5
BULLMQ_MAX_RETRIES=3

# Admin
ADMIN_EMAIL=admin@videosaver.com
